# Create .env.example with template
cat > .env.example << 'EOF'
# .env.example
# Copy this file to .env and add your actual API keys
# NEVER commit .env to GitHub!

# ============================================================
# Google Gemini API Key
# ============================================================
# Get your free API key from: https://aistudio.google.com/
# Click "Get API Key" → "Create API Key" → "Create API key in new project"
GOOGLE_API_KEY=your_api_key_here

# ============================================================
# Model Configuration
# ============================================================
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-pro
LLM_MODEL=gemini-1.5-flash

# Options: gemini-embedding-001
EMBEDDING_MODEL=gemini-embedding-001

# Temperature: 0.0 (factual) to 1.0 (creative)
TEMPERATURE=0.0

# ============================================================
# Document Processing
# ============================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=3

# ============================================================
# Storage
# ============================================================
CHROMA_PERSIST_DIR=./storage/chroma_db
FEEDBACK_STORAGE=./storage/feedback.json

# ============================================================
# Cache Configuration (Optional - Redis)
# ============================================================
CACHE_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL=3600

# ============================================================
# Supported File Types
# ============================================================
SUPPORTED_EXTENSIONS=.pdf,.txt,.md,.docx,.csv
EOF