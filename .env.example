# .env.example
# Copy this file to .env and add your actual API key
# NEVER commit .env to GitHub!

# ============================================================
# Groq API Key
# ============================================================
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_api_key_here

# ============================================================
# Model Configuration
# ============================================================
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile

# Local sentence-transformers model (downloaded automatically, no API key needed)
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Temperature: 0.0 (factual) to 1.0 (creative)
TEMPERATURE=0.0

# ============================================================
# Document Processing
# ============================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=3

# ============================================================
# Storage
# ============================================================
CHROMA_PERSIST_DIR=./storage/chroma_db
FEEDBACK_STORAGE=./storage/feedback.json

# ============================================================
# Cache Configuration (Optional - Redis)
# ============================================================
CACHE_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL=3600

# ============================================================
# Supported File Types
# ============================================================
SUPPORTED_EXTENSIONS=.pdf,.txt,.md,.docx,.csv
